# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# AES-256-GCM encryption key for stored API keys (hex-encoded 32 bytes)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
BOT_ENCRYPTION_KEY=

# Absolute path to the SQLite database file
DATABASE_PATH=./data/rk.db

# Your Telegram user ID — enables /broadcast and other owner commands
OWNER_USER_ID=

# Optional: pre-loaded provider keys (comma-separated for multiple)
# These are virtual keys and bypass DB storage
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Log level: debug | info | warning | error
LOG_LEVEL=info

# Agent display name shown in Telegram messages (optional, defaults to bot_name in config.json)
# Examples: lain, rei, Rika, aria
AGENT_NAME=